{
	"tabWidth": 4,
	"useTabs": true,
	"svelte": true,
	"sortTailwindcss": {
		"stylesheet": "./src/app.css"
	},
	"sortImports": {
		"internalPattern": ["~", "$"],
		"newlinesBetween": false
	},
	"ignorePatterns": [".agents/**", "src/assets/**"],
	"overrides": [
		{
			"files": ["*.yml", "*.yaml"],
			"options": {
				"tabWidth": 2,
				"useTabs": false
			}
		}
	]
}
