{
	"name": "hyperion",
	"type": "module",
	"private": true,
	"packageManager": "pnpm@10.24.0",
	"scripts": {
		"dev": "vite dev -d transform",
		"build": "vite build",
		"preview": "vite preview",
		"sync": "svelte-kit sync && gql-tada generate-output && gql-tada turbo",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"tauri": "tauri",
		"lint": "eslint \"src/**/*.{ts,svelte}\" && prettier --check src/**/*",
		"lint:fix": "eslint \"src/**/*.{ts,svelte}\" --fix && prettier --write src/**/*"
	},
	"prettier": {
		"printWidth": 100,
		"tabWidth": 4,
		"useTabs": true,
		"plugins": [
			"prettier-plugin-svelte",
			"prettier-plugin-tailwindcss"
		]
	},
	"dependencies": {
		"@better-fetch/fetch": "^1.1.21",
		"@dnd-kit-svelte/svelte": "^0.1.6",
		"@dnd-kit/abstract": "^0.3.2",
		"@dnd-kit/collision": "^0.3.2",
		"@dnd-kit/dom": "^0.3.2",
		"@dnd-kit/helpers": "^0.3.2",
		"@dnd-kit/svelte": "^0.3.2",
		"@tailwindcss/vite": "^4.2.0",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-clipboard-manager": "~2.3.2",
		"@tauri-apps/plugin-dialog": "~2.7.1",
		"@tauri-apps/plugin-fs": "~2.5.1",
		"@tauri-apps/plugin-notification": "~2.3.3",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@tauri-apps/plugin-os": "~2.3.2",
		"@tauri-apps/plugin-process": "~2.3.1",
		"@tauri-apps/plugin-updater": "~2.10.1",
		"@tauri-apps/plugin-window-state": "~2.4.1",
		"@tauri-store/svelte": "^3.2.0",
		"bits-ui": "^2.18.1",
		"chroma-js": "^3.2.0",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.20",
		"gql.tada": "^1.9.2",
		"graphql-web-lite": "16.6.0-4",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.4",
		"tauri-plugin-cache-api": "^0.1.6",
		"tldts": "^7.0.30",
		"virtua": "^0.49.1"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^8.2.0",
		"@gql.tada/svelte-support": "^1.0.2",
		"@iconify-json/ph": "^1.2.2",
		"@internationalized/date": "^3.12.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tauri-apps/cli": "^2.11.0",
		"@types/chroma-js": "^3.1.2",
		"eslint": "^10.3.0",
		"eslint-plugin-svelte": "^3.17.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"svelte-eslint-parser": "^1.6.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "~6.0.3",
		"unplugin-icons": "^23.0.1",
		"vite": "8.0.10",
		"vite-plugin-devtools-json": "^1.0.0"
	}
}
